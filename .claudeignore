# Claude Context Ignore — DomainForge
# Limits discovery (not access). For true access blocking, use .claude/settings.json deny-list.

# Dependencies
node_modules/
.next/
.turbo/

# Build outputs
dist/
out/
build/

# Environment files (never in context)
.env
.env.local
.env.production
.env.staging

# Supabase internals
supabase/.branches/
supabase/.temp/

# Generated files
*.generated.ts
supabase/types.ts

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
.pnpm-debug.log*

# Testing cache
.vitest/
coverage/

# Large data files
*.csv
*.json.bak
docs/context-dumps/

# Package manager
.yarn/
.pnp.*
